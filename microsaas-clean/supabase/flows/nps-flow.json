{
  "version": "7.0",
  "screens": [
    {
      "id": "NPS",
      "title": "Pesquisa de satisfação",
      "terminal": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "TextSubheading",
                "text": "De 0 a 10, o quanto você recomendaria a loja a um amigo?"
              },
              {
                "type": "Dropdown",
                "name": "nota",
                "label": "Sua nota",
                "required": true,
                "data-source": [
                  { "id": "10", "title": "10 · Com certeza recomendo!" },
                  { "id": "9", "title": "9" },
                  { "id": "8", "title": "8" },
                  { "id": "7", "title": "7" },
                  { "id": "6", "title": "6" },
                  { "id": "5", "title": "5" },
                  { "id": "4", "title": "4" },
                  { "id": "3", "title": "3" },
                  { "id": "2", "title": "2" },
                  { "id": "1", "title": "1" },
                  { "id": "0", "title": "0 · Não recomendo" }
                ]
              },
              {
                "type": "TextArea",
                "name": "comentario",
                "label": "Quer contar mais? (opcional)",
                "required": false
              },
              {
                "type": "Footer",
                "label": "Enviar avaliação",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "nota": "${form.nota}",
                    "comentario": "${form.comentario}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
