@@ -0,0 +1,17 @@
+// Código de indicação (Indique e Ganhe / TCF).
+// Lê o ?ref da URL (página /veiculo/[id]?ref=CODIGO), persiste e devolve.
+const KEY = 'totex_ref';
+
+export function getRef(): string | undefined {
+  if (typeof window === 'undefined') return undefined;
+  try {
+    const fromUrl = new URL(window.location.href).searchParams.get('ref');
+    if (fromUrl) {
+      try { localStorage.setItem(KEY, fromUrl); } catch { /* ignore */ }
+      return fromUrl;
+    }
+    return localStorage.getItem(KEY) || undefined;
+  } catch {
+    return undefined;
+  }
+}
