 import { CreateVehicleDto } from './dto/create-vehicle.dto';
@@ -20,11 +20,54 @@ const SEARCHABLE_VEHICLE_FIELDS = [
 
 @Injectable()
 export class VehiclesService {
+  private readonly logger = new Logger(VehiclesService.name);
+
   constructor(
     private readonly prisma: PrismaService,
     private readonly fipeService: FipeService,
   ) {}
 
+  /**
+   * Indique e Ganhe (TCF): quando um veículo é marcado como VENDIDO e houve um
+   * lead com código de indicação (?ref), reporta a venda ao TCF para creditar a
+   * comissão do indicador. Não bloqueia/derruba o update (best-effort).
+   * Configurar no backend: TCF_INTEGRATION_URL, TCF_INTEGRATION_KEY, REFERRAL_COMMISSION.
+   */
+  private async reportReferralOnSale(vehicleId: string): Promise<void> {
+    const url = process.env.TCF_INTEGRATION_URL;
+    const key = process.env.TCF_INTEGRATION_KEY;
+    if (!url || !key) return; // integração não configurada — ignora
+
+    const leads = await this.prisma.lead.findMany({
+      where: { vehicleId },
+      orderBy: { createdAt: 'desc' },
+      take: 50,
+    });
+    const refLead = leads.find(
+      (l) => l.metadata && typeof l.metadata === 'object' && (l.metadata as any).ref,
+    );
+    if (!refLead) return; // venda sem indicação
+
+    const ref = (refLead.metadata as any).ref as string;
+    const vehicle = await this.prisma.vehicle.findUnique({ where: { id: vehicleId } });
+    const commission = Number(process.env.REFERRAL_COMMISSION || 0);
+
+    const res = await fetch(url, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json', 'x-api-key': key },
+      body: JSON.stringify({
+        action: 'report_referral',
+        owner_code: ref,
+        type: 'sale',
+        value: commission,
+        car_external_id: vehicleId,
+        car_title: vehicle ? `${vehicle.brand} ${vehicle.model} ${vehicle.year}` : undefined,
+      }),
+    });
+    if (!res.ok) throw new Error(`TCF report_referral ${res.status}`);
+    this.logger.log(`Indicação reportada ao TCF: veículo ${vehicleId} (ref ${ref})`);
+  }
+
   /**
    * Busca os IDs dos veículos que casam com o termo, ignorando acentuação e
    * maiúsculas/minúsculas (via extensão unaccent do PostgreSQL).
@@ -336,6 +379,13 @@ export class VehiclesService {
